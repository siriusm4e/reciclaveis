# =============================================================================
# Plataforma Nacional de Resíduos (PNR) — variáveis de ambiente
# Copie para .env (NÃO commitado) e ajuste os valores.
# =============================================================================

# ----- App -----
APP_NAME=PNR
APP_ENV=development            # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
TZ=America/Sao_Paulo

# ----- Postgres -----
POSTGRES_DB=pnr
POSTGRES_USER=pnr
POSTGRES_PASSWORD=trocar_essa_senha
POSTGRES_PORT=5432
# Backend lê a URL diretamente; a forma asyncpg é injetada no docker-compose.
DATABASE_URL=postgresql+asyncpg://pnr:trocar_essa_senha@postgres:5432/pnr
# URL síncrona usada pelo Alembic em runtime
DATABASE_URL_SYNC=postgresql+psycopg2://pnr:trocar_essa_senha@postgres:5432/pnr

# ----- Redis -----
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
JWT_BLOCKLIST_REDIS_URL=redis://redis:6379/3
WS_PUBSUB_REDIS_URL=redis://redis:6379/4

# ----- JWT / Auth -----
# Gere uma chave forte com: openssl rand -hex 64
JWT_SECRET_KEY=troque_para_uma_chave_de_64_chars_aleatoria_hex
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7
JWT_ISSUER=pnr-api

# Argon2id parâmetros OWASP 2024
ARGON2_MEMORY_COST=19456       # KiB
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# MFA
MFA_ISSUER=PNR
MFA_LOGIN_LOCK_THRESHOLD=5     # tentativas falhas antes de bloquear sessão

# ----- CORS -----
# Comma-separated. NUNCA usar "*" em produção.
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173,capacitor://localhost,ionic://localhost

# ----- Backend / Frontend / Nginx ports -----
BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=80

# ----- Frontend -----
VITE_API_URL=/api
VITE_WS_URL=/ws
VITE_API_PROXY_TARGET=http://backend:8000
VITE_WS_PROXY_TARGET=ws://backend:8000

# ----- Uploads -----
UPLOAD_MAX_BYTES=10485760      # 10 MB
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,image/webp,application/pdf
STORAGE_BASE_PATH=/app/storage
STORAGE_PUBLIC_URL=/storage    # servido pelo nginx

# ----- Geolocalização / Privacidade -----
GEO_OFFSET_URBANO_M=250        # offset mínimo urbano (≥ 200m)
GEO_OFFSET_RURAL_M=1500        # offset mínimo rural (≥ 1km)
GEO_DEFAULT_SRID=4326

# ----- Receita Federal (CPF/CNPJ) -----
# Stub no MVP; em prod, configurar provedor real (Serpro, Hub Dev, etc.)
RECEITA_PROVIDER=stub          # stub | hubdev | serpro
RECEITA_API_TOKEN=

# ----- Push notifications -----
# Firebase Admin SDK — cole o JSON em base64 ou aponte para arquivo no container
FCM_CREDENTIALS_JSON_BASE64=
FCM_PROJECT_ID=
# Capacitor lê client config nativo (google-services.json / GoogleService-Info.plist)

# ----- Alerta Pago / Créditos -----
ALERTA_PAGO_COBERTURA_MINIMA=3 # se < 3 contas elegíveis no raio → reembolso
CREDITOS_EXPIRAM=false         # MVP: créditos sem expiração

# ----- Oportunidades públicas -----
OPORTUNIDADE_PUBLICA_PRAZO_MIN_DIAS_UTEIS=5

# ----- LGPD -----
LGPD_GRACA_EXCLUSAO_DIAS=30
AUDIT_LOG_RETENCAO_ANOS=5

# ----- Observabilidade -----
METRICS_TOKEN=troque_para_um_token_aleatorio   # X-Metrics-Token / Authorization
OTEL_SERVICE_NAME=pnr-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# ----- Rate limiting (slowapi) -----
RATE_LIMIT_PUBLIC=100/minute
RATE_LIMIT_AUTHENTICATED=1000/minute

# ----- Grafana / Prometheus -----
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
JAEGER_UI_PORT=16686

# ----- Superadmin inicial (seed) -----
SUPERADMIN_EMAIL=admin@pnr.com.br
SUPERADMIN_PASSWORD=trocar_no_primeiro_login
SUPERADMIN_CPF=00000000000
